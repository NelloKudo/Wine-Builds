From 33746822e2be28b1805a8c3ae2481f7c2f9ea664 Mon Sep 17 00:00:00 2001
From: NelloKudo <marshnelloosu@gmail.com>
Date: Mon, 6 Apr 2026 21:31:10 +0200
Subject: [PATCH 09/12] winex11/win32u: Enable grab_fullscreen by default.

---
 dlls/win32u/input.c            | 2 +-
 dlls/winex11.drv/x11drv_main.c | 2 +-
 programs/winecfg/input.c       | 2 +-
 3 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/dlls/win32u/input.c b/dlls/win32u/input.c
index 10390f83956..4780755a090 100644
--- a/dlls/win32u/input.c
+++ b/dlls/win32u/input.c
@@ -409,7 +409,7 @@ static const KBDTABLES kbdus_tables =
 static LONG clipping_cursor; /* clipping thread counter */
 
 BOOL grab_pointer = TRUE;
-BOOL grab_fullscreen = FALSE;
+BOOL grab_fullscreen = TRUE;
 
 static void kbd_tables_init_vsc2vk( const KBDTABLES *tables, USHORT vsc2vk[0x300] )
 {
diff --git a/dlls/winex11.drv/x11drv_main.c b/dlls/winex11.drv/x11drv_main.c
index 185850cdf60..d54e9c78fff 100644
--- a/dlls/winex11.drv/x11drv_main.c
+++ b/dlls/winex11.drv/x11drv_main.c
@@ -73,7 +73,7 @@ BOOL use_xfixes = FALSE;
 BOOL use_take_focus = TRUE;
 BOOL use_primary_selection = FALSE;
 BOOL use_system_cursors = TRUE;
-BOOL grab_fullscreen = FALSE;
+BOOL grab_fullscreen = TRUE;
 int keyboard_layout = -1;
 BOOL keyboard_scancode_detect = FALSE;
 BOOL managed_mode = TRUE;
diff --git a/programs/winecfg/input.c b/programs/winecfg/input.c
index 3ee20d49874..4501190abf4 100644
--- a/programs/winecfg/input.c
+++ b/programs/winecfg/input.c
@@ -43,7 +43,7 @@ static void init_dialog( HWND dialog )
 
     updating_ui = TRUE;
 
-    buffer = get_reg_key( config_key, keypath( L"X11 Driver" ), L"GrabFullscreen", L"N" );
+    buffer = get_reg_key( config_key, keypath( L"X11 Driver" ), L"GrabFullscreen", L"Y" );
     if (IS_OPTION_TRUE( *buffer )) CheckDlgButton( dialog, IDC_FULLSCREEN_GRAB, BST_CHECKED );
     else CheckDlgButton( dialog, IDC_FULLSCREEN_GRAB, BST_UNCHECKED );
     free( buffer );
-- 
2.53.0

