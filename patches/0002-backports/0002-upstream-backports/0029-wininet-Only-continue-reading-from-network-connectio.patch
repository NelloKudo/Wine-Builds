From e3d6c7a415693f8be4df6839cf370c2892aee2f1 Mon Sep 17 00:00:00 2001
From: Torge Matthies <openglfreak@googlemail.com>
Date: Fri, 6 Mar 2026 02:27:38 +0100
Subject: [PATCH 29/35] wininet: Only continue reading from network connection
 in InternetReadFile if read position matches cache write position.

---
 dlls/wininet/http.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/dlls/wininet/http.c b/dlls/wininet/http.c
index 2241c12a436..ae41311d3ba 100644
--- a/dlls/wininet/http.c
+++ b/dlls/wininet/http.c
@@ -3243,7 +3243,7 @@ static void async_read_file_proc(task_header_t *hdr)
         }
     }
 
-    if(task->buf) {
+    if(task->buf && req->content_pos == req->file_pos) {
         DWORD read_bytes;
         while (read < task->size) {
             res = HTTPREQ_Read(req, (char*)task->buf + read, task->size - read, &read_bytes, TRUE);
@@ -3379,7 +3379,7 @@ static DWORD HTTPREQ_ReadFile(object_header_t *hdr, void *buf, DWORD size, DWORD
             }
         }
 
-        if(res == ERROR_SUCCESS && read < size && (!read || !(flags & IRF_NO_WAIT)) && !end_of_read_data(req)) {
+        if(res == ERROR_SUCCESS && req->content_pos == req->file_pos && read < size && (!read || !(flags & IRF_NO_WAIT)) && !end_of_read_data(req)) {
             LeaveCriticalSection(&req->read_section);
             INTERNET_SendCallback(&req->hdr, req->hdr.dwContext, INTERNET_STATUS_RECEIVING_RESPONSE, NULL, 0);
             EnterCriticalSection( &req->read_section );
-- 
