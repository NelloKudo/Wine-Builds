-    INTERNET_SendCallback(&request->hdr, request->hdr.dwContext,
+    send_callback(request, request->hdr.dwContext,
                   INTERNET_STATUS_RESPONSE_RECEIVED, &responseLen, sizeof(DWORD));
 
     /* process cookies here. Is this right? */
@@ -6106,7 +6110,7 @@ static void HTTP_clear_response_headers( http_request_t *request )
  *   TRUE  on success
  *   FALSE on error
  */
-static DWORD HTTP_GetResponseHeaders(http_request_t *request, INT *len)
+static DWORD HTTP_GetResponseHeaders(http_request_t *request, INT *len, BOOL restarting)
 {
     INT cbreaks = 0;
     WCHAR buffer[MAX_REPLY_LEN];
@@ -6123,7 +6127,8 @@ static DWORD HTTP_GetResponseHeaders(http_request_t *request, INT *len)
         goto lend;
 
     /* clear old response headers (eg. from a redirect response) */
