From 63760415934e41b62f10e8dadd3433fc8fb4092c Mon Sep 17 00:00:00 2001
From: Torge Matthies <openglfreak@googlemail.com>
Date: Fri, 6 Mar 2026 02:27:39 +0100
Subject: [PATCH 34/35] wininet: Restart request if seeking a distance of 12
 KiB or more.

---
 dlls/wininet/http.c     | 46 ++++++++++++++++++++++++++++++++++++++++-
 dlls/wininet/internet.h |  1 +
 2 files changed, 46 insertions(+), 1 deletion(-)

diff --git a/dlls/wininet/http.c b/dlls/wininet/http.c
index 2d3887fb86d..89915891580 100644
--- a/dlls/wininet/http.c
+++ b/dlls/wininet/http.c
@@ -62,6 +62,8 @@ WINE_DEFAULT_DEBUG_CHANNEL(wininet);
 
 #define COLLECT_TIME 60000
 
+#define MIN_RESTART_DISTANCE 12288
+
 struct HttpAuthInfo
 {
     LPWSTR scheme;
@@ -3140,6 +3142,9 @@ static void HTTP_ReceiveRequestData(http_request_t *req)
     send_request_complete(req, req->session->hdr.dwInternalFlags & INET_OPENURL ? (DWORD_PTR)req->hdr.hInternet : 1, 0);
 }
 
+static DWORD create_request(http_request_t *request, void *optional, DWORD optlen, DWORD content_length,
+                            BOOL restarting, BOOL end_request);
+
 static DWORD read_req_file(http_request_t *req, BYTE *buffer, DWORD size, DWORD *read, BOOL allow_blocking)
 {
     DWORD ret_read = 0, res;
@@ -3147,6 +3152,24 @@ static DWORD read_req_file(http_request_t *req, BYTE *buffer, DWORD size, DWORD
     BYTE buf[1024];
     ULONGLONG end;
 
+    if(req->restart_request) {
+        req->restart_request = FALSE;
+
+        if(!req->range_hdr_not_supported) {
+            TRACE("restarting request\n");
+
+            if (req->content_pos < req->contentLength)
+                res = create_request(req, NULL, 0, 0, TRUE, TRUE);
+            else
+                res = ERROR_NOACCESS;
+            if (res != ERROR_SUCCESS) {
+                req->state = ERROR_INTERNET_INCORRECT_HANDLE_STATE;
+                *read = 0;
+                return ERROR_NOACCESS;
+            }
+        }
+    }
+
     while (req->content_pos > find_range_end(req, req->content_pos)) {
         res = read_http_stream(req, (BYTE*)buf, min(sizeof(buf), req->content_pos - req->file_pos),
                                &ret_read, allow_blocking);
@@ -3258,6 +3281,23 @@ static void async_read_file_proc(task_header_t *hdr)
 
     TRACE("req %p buf %p size %lu read_pos %lu ret_read %p\n", req, task->buf, task->size, task->read_pos, task->ret_read);
 
+    if(req->restart_request) {
+        req->restart_request = FALSE;
+
+        if(!req->range_hdr_not_supported) {
+            if (req->content_pos < req->contentLength)
+                res = create_request(req, NULL, 0, 0, TRUE, TRUE);
+            else
+                res = ERROR_NOACCESS;
+            if (res != ERROR_SUCCESS) {
+                if(task->ret_read)
+                    *task->ret_read = 0;
+                send_request_complete(req, FALSE, ERROR_NOACCESS);
+                return;
+            }
+        }
+    }
+
     if(req->req_file && req->req_file->file_handle) {
         DWORD ret, ret_read;
         BYTE buf[1024];
@@ -3362,9 +3402,13 @@ static DWORD HTTPREQ_SetFilePointer(object_header_t *hdr, LONG lDistanceToMove,
             break;
     }
 
-    if(err == ERROR_SUCCESS) {
+    if(err == ERROR_SUCCESS && req->content_pos != res) {
         req->content_pos = res;
         req->read_pos = req->read_size = 0;
+        if(!req->range_hdr_not_supported && find_range_end(req, req->content_pos) < req->content_pos &&
+            (ULONGLONG)(req->content_pos - req->file_pos) > MIN_RESTART_DISTANCE) {
+            req->restart_request = TRUE;
+        }
     }
 
     LeaveCriticalSection(&req->read_section);
diff --git a/dlls/wininet/internet.h b/dlls/wininet/internet.h
index 71d8fd4724e..8751bf06aa3 100644
--- a/dlls/wininet/internet.h
+++ b/dlls/wininet/internet.h
@@ -331,6 +331,7 @@ typedef struct
     DWORD bytesToWrite;
     DWORD bytesWritten;
     BOOL clear_auth; /* Flag to clear the password field on the authorization dialog */
+    BOOL restart_request;
     BOOL restarting;
 
     CRITICAL_SECTION headers_section;  /* section to protect the headers array */
-- 
2.53.0

