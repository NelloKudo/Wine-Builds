From eb6ad6b154cf9cf7923a6b49d76c79dfb70c2719 Mon Sep 17 00:00:00 2001
From: Torge Matthies <openglfreak@googlemail.com>
Date: Fri, 6 Mar 2026 02:27:39 +0100
Subject: [PATCH 31/35] wininet: Add "with_range" parameter to
 build_request_header for adding a Range header.

---
 dlls/wininet/http.c     | 42 ++++++++++++++++++++++++++++++++++-------
 dlls/wininet/internet.h |  1 +
 2 files changed, 36 insertions(+), 7 deletions(-)

diff --git a/dlls/wininet/http.c b/dlls/wininet/http.c
index f208a1f5aaa..31b4bee6e15 100644
--- a/dlls/wininet/http.c
+++ b/dlls/wininet/http.c
@@ -540,8 +540,20 @@ static void HTTP_FixURL(http_request_t *request)
     }
 }
 
+static ULONGLONG find_hole_end(http_request_t *req, ULONGLONG pos)
+{
+    http_downloaded_range_t *entry;
+
+    LIST_FOR_EACH_ENTRY(entry, &req->downloaded_ranges, http_downloaded_range_t, entry)
+    {
+        if (entry->start >= pos)
+            return entry->start;
+    }
+    return -1ULL;
+}
+
 static WCHAR* build_request_header(http_request_t *request, const WCHAR *verb,
-        const WCHAR *path, const WCHAR *version, BOOL use_cr)
+        const WCHAR *path, const WCHAR *version, BOOL use_cr, BOOL with_range)
 {
     LPWSTR requestString;
     DWORD len, n;
@@ -551,7 +563,7 @@ static WCHAR* build_request_header(http_request_t *request, const WCHAR *verb,
     EnterCriticalSection( &request->headers_section );
 
     /* allocate space for an array of all the string pointers to be added */
-    len = request->nCustHeaders * 5 + 10;
+    len = request->nCustHeaders * 5 + 14;
     if (!(req = malloc( len * sizeof(const WCHAR *) )))
     {
         LeaveCriticalSection( &request->headers_section );
@@ -586,6 +598,22 @@ static WCHAR* build_request_header(http_request_t *request, const WCHAR *verb,
                    debugstr_w(request->custHeaders[i].lpszValue));
         }
     }
+    if (with_range && request->content_pos > 0)
+    {
+        ULONGLONG range_end = find_hole_end(request, request->content_pos);
+        if (range_end == -1ULL)
+            swprintf(request->range_hdr_value, ARRAY_SIZE(request->range_hdr_value),
+                     L"%I64u-", request->content_pos);
+        else
+            swprintf(request->range_hdr_value, ARRAY_SIZE(request->range_hdr_value),
+                     L"%I64u-%I64u", request->content_pos, range_end - 1);
+        req[n++] = L"Range: bytes=";
+        req[n++] = request->range_hdr_value;
+        if (use_cr)
+            req[n++] = L"\r";
+        req[n++] = L"\n";
+        TRACE("Adding Range header \"Range: bytes=%s\"\n", debugstr_w(request->range_hdr_value));
+    }
     if (use_cr)
         req[n++] = L"\r";
     req[n++] = L"\n";
@@ -3809,7 +3837,7 @@ static DWORD HTTP_HttpQueryInfoW(http_request_t *request, DWORD dwInfoLevel,
             DWORD res = ERROR_INVALID_PARAMETER;
 
             if (request_only)
-                headers = build_request_header(request, request->verb, request->path, request->version, TRUE);
+                headers = build_request_header(request, request->verb, request->path, request->version, TRUE, FALSE);
             else
                 headers = build_response_header(request, TRUE);
             if (!headers)
@@ -3842,7 +3870,7 @@ static DWORD HTTP_HttpQueryInfoW(http_request_t *request, DWORD dwInfoLevel,
             DWORD len;
 
             if (request_only)
-                headers = build_request_header(request, request->verb, request->path, request->version, FALSE);
+                headers = build_request_header(request, request->verb, request->path, request->version, FALSE, FALSE);
             else
                 headers = build_response_header(request, FALSE);
 
@@ -5156,12 +5184,12 @@ static DWORD create_request(http_request_t *request, void *optional, DWORD optle
             if (HTTP_GetCustomHeaderIndex(request, L"Content-Length", 0, TRUE) >= 0)
                 set_content_length_header(request, 0, HTTP_ADDREQ_FLAG_REPLACE);
 
-            request_header = build_request_header(request, L"CONNECT", target, L"HTTP/1.1", TRUE);
+            request_header = build_request_header(request, L"CONNECT", target, L"HTTP/1.1", TRUE, FALSE);
         }
         else if (request->proxy && !(request->hdr.dwFlags & INTERNET_FLAG_SECURE))
         {
             WCHAR *url = build_proxy_path_url(request);
-            request_header = build_request_header(request, request->verb, url, request->version, TRUE);
+            request_header = build_request_header(request, request->verb, url, request->version, TRUE, FALSE);
             free(url);
         }
         else
@@ -5169,7 +5197,7 @@ static DWORD create_request(http_request_t *request, void *optional, DWORD optle
             if (request->proxy && HTTP_GetCustomHeaderIndex(request, L"Content-Length", 0, TRUE) >= 0)
                 set_content_length_header(request, content_length, HTTP_ADDREQ_FLAG_REPLACE);
 
-            request_header = build_request_header(request, request->verb, request->path, request->version, TRUE);
+            request_header = build_request_header(request, request->verb, request->path, request->version, TRUE, FALSE);
         }
 
         TRACE("Request header -> %s\n", debugstr_w(request_header) );
diff --git a/dlls/wininet/internet.h b/dlls/wininet/internet.h
index 6dc2427b29e..3dc0ec934a9 100644
--- a/dlls/wininet/internet.h
+++ b/dlls/wininet/internet.h
@@ -342,6 +342,7 @@ typedef struct
     ULONGLONG file_pos;
     struct list downloaded_ranges;
     req_file_t *req_file;
+    WCHAR range_hdr_value[42];
     FILETIME expires;
     struct HttpAuthInfo *authInfo;
     struct HttpAuthInfo *proxyAuthInfo;
-- 
2.53.0

